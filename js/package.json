{
  "name": "kiahk",
  "version": "0.1.0",
  "description": "Coptic calendar arithmetic — date conversion, Easter, and feast days",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["coptic", "calendar", "easter", "coptic-calendar", "kiahk"],
  "author": "WizardLabz",
  "contributors": [
    { "name": "Amir Magdy" }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amir-magdy-of-wizardlabz/kiahk.git",
    "directory": "js"
  },
  "homepage": "https://github.com/amir-magdy-of-wizardlabz/kiahk#readme",
  "bugs": {
    "url": "https://github.com/amir-magdy-of-wizardlabz/kiahk/issues"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
