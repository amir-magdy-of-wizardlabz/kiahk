{
  "name": "kiahk",
  "version": "0.1.0",
  "description": "Coptic calendar arithmetic — date conversion, Easter, and feast days. Works in Node and the browser.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "coptic",
    "calendar",
    "easter",
    "coptic-calendar",
    "kiahk",
    "kiahk-calendar",
    "orthodox",
    "feast",
    "aboqty",
    "قبطي",
    "تقويم",
    "كيهك",
    "عيد",
    "القيامة",
    "القيامه",
    "أبوقطي"
  ],
  "author": "WizardLabz",
  "contributors": [
    { "name": "Amir Magdy" }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amir-magdy-of-wizardlabz/kiahk.git",
    "directory": "js"
  },
  "homepage": "https://github.com/amir-magdy-of-wizardlabz/kiahk#readme",
  "bugs": {
    "url": "https://github.com/amir-magdy-of-wizardlabz/kiahk/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
